  场景 2：手动构建 Mark

  import { encodeCompositePageNum } from '@shared/utils/pageMapping';
  import { usePageSubmission } from '@shared/services/submission';

  function MyComponent() {
    const stepIndex = 1;   // 当前在第 1 步
    const subPageNum = 8;  // 该步骤的第 8 页

    // 生成 pageNumber
    const pageNumber = encodeCompositePageNum(stepIndex, subPageNum); // "1.8"

    const { submit } = usePageSubmission({
      pageMeta: {
        pageId: 'question-8',
        pageTitle: '第8题',
        stepIndex,
        subPageNum
      },
      getUserContext,
      getFlowContext
    });

    // 提交时会自动使用正确的 pageNumber
  }

  场景 3：后端恢复逻辑

  // 后端返回的恢复点
  const resumeData = {
    flowId: 'g7a-mix-001',
    pageNum: '1.5'  // 字符串格式
  };

  // 前端解析
  import { parseCompositePageNum } from '@shared/utils/pageMapping';

  const parsed = parseCompositePageNum(resumeData.pageNum);
  // {
  //   stepIndex: 1,   // 解析出步骤索引
  //   subPageNum: 5   // 解析出子页码
  // }

  // 使用解析结果
  const flowDef = getFlowDefinition(resumeData.flowId);
  const step = flowDef.steps[parsed.stepIndex];
  const submodule = loadSubmodule(step.submoduleId);
  const pageId = submodule.getInitialPage(String(parsed.subPageNum));

  // 导航到正确位置
  navigate(pageId);

  ---
  ⚙️ Schema 校验规则

  当前 Schema 会执行以下严格校验：

  // src/shared/services/submission/schema.ts

  // 正则：仅允许点分格式
  const PAGE_NUMBER_PATTERN = /^\d+\.\d+$/;

  function isValidPageNumber(pageNum: string): boolean {
    return PAGE_NUMBER_PATTERN.test(pageNum);
  }

  // 校验示例
  isValidPageNumber('0.3')   // ✅ true
  isValidPageNumber('1.5')   // ✅ true
  isValidPageNumber('2.10')  // ✅ true

  isValidPageNumber('1')     // ❌ false - 单数字
  isValidPageNumber('M0:3')  // ❌ false - M 前缀
  isValidPageNumber('0-3')   // ❌ false - 错误分隔符

  违规提交会被拒绝：
  ❌ ZodError: pageNumber 必须为 Flow 点分格式 <stepIndex>.<subPageNum>（如 "0.3"），
     不再支持 M 前缀或单数字格式


  🔍 调试技巧

  1. 验证 pageNumber 格式

  import { isValidPageNumber } from '@shared/services/submission/schema';

  const pageNumber = '1.5';
  if (!isValidPageNumber(pageNumber)) {
    console.error('❌ pageNumber 格式不符合规范');
  } else {
    console.log('✅ pageNumber 格式正确');
  }

  2. 解析和重建

  import {
    parseCompositePageNum,
    encodeCompositePageNum
  } from '@shared/utils/pageMapping';

  const pageNumber = '1.5';

  // 解析
  const parsed = parseCompositePageNum(pageNumber);
  console.log(parsed); // { stepIndex: 1, subPageNum: 5 }

  // 重建
  const rebuilt = encodeCompositePageNum(parsed.stepIndex, parsed.subPageNum);
  console.log(rebuilt === pageNumber); // true

  3. 检查提交数据

  // 在提交前打印
  console.log('提交数据预览：', {
    pageNumber,
    targetElement: `P${pageNumber}_button_next`, // 应该带前缀
    pageDesc: buildPageDescPrefix(flowId, submoduleId, stepIndex) + pageTitle
  });

